rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // Security rules for user configuration documents
    match /users/{userId} {
      // Allow read/write only if the authenticated user matches the document ID and specific admin UID.
      allow read, write: if request.auth != null 
                          && request.auth.uid == userId 
                          && request.auth.uid == "KC0LUzTuQbZ1FncBxxyi7XgdSxx1";
    }
  }
}
