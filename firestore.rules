rules_version = '2';

service cloud.firestore {
  match /databases/{database}/documents {
    // ユーザー設定情報のドキュメントセキュリティ
    match /users/{userId} {
      // 以下の 'YOUR_FIREBASE_AUTH_UID_HERE' をご自身の Firebase Auth UID（環境変数 RPG_UID の値）に書き換えてください。
      // これにより、登録された他の誰かではなく、あなただけがこのドキュメントを読み書きできるようになります。
      allow read, write: if request.auth != null 
                          && request.auth.uid == userId 
                          && request.auth.uid == "YOUR_FIREBASE_AUTH_UID_HERE";
    }
  }
}
